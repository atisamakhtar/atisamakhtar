    "@types/react-dom": "^19.0.3",
    "@types/three": "0.172.0",
    "autoprefixer": "10.5.0",
    "cross-env": "10.1.0",
    "eslint": "10.4.1",
    "eslint-config-next": "^16.2.9",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
