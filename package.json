{
  "name": "atisam-akhtar-portfolio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\"",
    "prepare": "node -e \"if (process.env.CI !== '1' && process.env.VERCEL !== '1') { require('child_process').execSync('husky', { stdio: 'inherit' }) }\"",
    "analyze": "cross-env ANALYZE=true next build",
    "audit:fix": "npm audit fix"
  },
  "dependencies": {
    "@gsap/react": "2.1.2",
    "@hookform/resolvers": "5.4.0",
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "@upstash/ratelimit": "2.0.8",
    "@upstash/redis": "1.38.0",
    "@vercel/og": "0.11.1",
    "framer-motion": "12.40.0",
    "gsap": "3.15.0",
    "isomorphic-dompurify": "3.16.0",
    "lucide-react": "1.17.0",
    "next": "^16.2.7",
    "next-mdx-remote": "6.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "7.78.0",
    "shiki": "4.2.0",
    "split-type": "0.3.4",
    "three": "0.184.0",
    "vanilla-tilt": "1.8.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.2.0",
    "@next/bundle-analyzer": "^15.3.8",
    "@types/node": "22.10.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "0.172.0",
    "autoprefixer": "10.4.20",
    "cross-env": "7.0.3",
    "eslint": "9.17.0",
    "eslint-config-next": "^15.3.8",
    "husky": "9.1.7",
    "lint-staged": "15.2.11",
    "postcss": "8.4.49",
    "prettier": "3.4.2",
    "prettier-plugin-tailwindcss": "0.6.9",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,md,json}": [
      "prettier --write"
    ]
  }
}
